rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       AUTH HELPERS
    ========================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/cafeUsers/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/cafeUsers/$(request.auth.uid)).data;
    }

    function isCafeUser(cafeId) {
      return hasUserDoc() &&
        getUserData().cafeId == cafeId;
    }

    function isOwner(cafeId) {
      return isCafeUser(cafeId) &&
        getUserData().role == "owner";
    }

    function isManager(cafeId) {
      return isCafeUser(cafeId) &&
        getUserData().role == "manager";
    }

    function isOwnerOrManager(cafeId) {
      return isOwner(cafeId) || isManager(cafeId);
    }

    function canAccessByResourceOrRequestCafeId() {
      return isAuthenticated() && (
        (
          resource.data.cafeId is string &&
          isOwnerOrManager(resource.data.cafeId)
        ) ||
        (
          request.resource.data.cafeId is string &&
          isOwnerOrManager(request.resource.data.cafeId)
        )
      );
    }

    /* =========================
       CAFES
    ========================= */

    match /cafes/{cafeId} {
      allow read: if isOwnerOrManager(cafeId);
      allow create: if false;
      allow update, delete: if isOwner(cafeId);
    }

    /* =========================
       USERS
    ========================= */

    match /cafeUsers/{userId} {
      allow get: if isAuthenticated() &&
        request.auth.uid == userId;

      allow list: if false;
      allow create, update, delete: if false;
    }

    /* =========================
       TABLES
    ========================= */

    match /tables/{tableId} {

      allow read: if isAuthenticated()
        && resource.data.cafeId is string
        && isOwnerOrManager(resource.data.cafeId);

      allow create: if isAuthenticated()
        && request.resource.data.cafeId is string
        && isOwnerOrManager(request.resource.data.cafeId);

      allow update: if canAccessByResourceOrRequestCafeId();

      allow delete: if canAccessByResourceOrRequestCafeId();
    }

    /* =========================
       TABLE ITEMS
    ========================= */

    match /tableItems/{itemId} {

      allow read: if isAuthenticated()
        && resource.data.cafeId is string
        && isOwnerOrManager(resource.data.cafeId);

      allow create: if isAuthenticated()
        && request.resource.data.cafeId is string
        && isOwnerOrManager(request.resource.data.cafeId);

      allow update: if canAccessByResourceOrRequestCafeId();

      /* KRİTİK FIX */
      allow delete: if canAccessByResourceOrRequestCafeId();
    }

    /* =========================
       ACTIVITY LOGS
    ========================= */

    match /tableActivityLogs/{logId} {

      allow read: if isAuthenticated()
        && resource.data.cafeId is string
        && isOwnerOrManager(resource.data.cafeId);

      allow create: if isAuthenticated()
        && request.resource.data.cafeId is string
        && isOwnerOrManager(request.resource.data.cafeId);

      allow update, delete: if false;
    }

    /* =========================
       PUBLIC TABLES
    ========================= */

    match /publicTables/{token} {

      allow read: if resource.data.deletedAt == null;

      allow create, update, delete: if isAuthenticated();
    }

    /* =========================
       COMPLETED SESSIONS
    ========================= */

    match /completedSessions/{sessionId} {

      allow read: if isAuthenticated()
        && resource.data.cafeId is string
        && isOwnerOrManager(resource.data.cafeId);

      allow create: if isAuthenticated()
        && request.resource.data.cafeId is string
        && isOwnerOrManager(request.resource.data.cafeId);

      allow update, delete: if canAccessByResourceOrRequestCafeId();
    }

    /* =========================
       PAYMENTS
    ========================= */

    match /payments/{paymentId} {
      allow read, write: if false;
    }

    /* =========================
       FALLBACK
    ========================= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isAuthenticated() && exists(/databases/$(database)/documents/cafeUsers/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/cafeUsers/$(request.auth.uid)).data;
    }

    function isCafeUser(cafeId) {
      return hasUserDoc() && getUserData().cafeId == cafeId;
    }

    function isOwner(cafeId) {
      return isCafeUser(cafeId) && getUserData().role == 'owner';
    }

    function isManager(cafeId) {
      return isCafeUser(cafeId) && getUserData().role == 'manager';
    }

    function isOwnerOrManager(cafeId) {
      return isOwner(cafeId) || isManager(cafeId);
    }

    function isNonNegativeNumber(value) {
      return value is number && value >= 0;
    }

    function tableDoc(tableId) {
      return get(/databases/$(database)/documents/tables/$(tableId)).data;
    }

    function tableExists(tableId) {
      return exists(/databases/$(database)/documents/tables/$(tableId));
    }

    function tableBelongsToCafe(tableId, cafeId) {
      return tableExists(tableId) && tableDoc(tableId).cafeId == cafeId;
    }

    function isSafeTableCreate() {
      return request.resource.data.cafeId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.status in ['empty', 'occupied', 'payment_pending', 'closed']
        && request.resource.data.publicToken is string
        && request.resource.data.publicToken.size() >= 24
        && request.resource.data.deletedAt == null
        && isNonNegativeNumber(request.resource.data.totalAmount)
        && isNonNegativeNumber(request.resource.data.itemCount)
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number
        && request.resource.data.lastActivityAt is number;
    }

    function isSafeTableUpdate() {
      return request.resource.data.cafeId == resource.data.cafeId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.status in ['empty', 'occupied', 'payment_pending', 'closed']
        && request.resource.data.publicToken is string
        && request.resource.data.publicToken.size() >= 24
        && isNonNegativeNumber(request.resource.data.totalAmount)
        && isNonNegativeNumber(request.resource.data.itemCount)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is number
        && request.resource.data.lastActivityAt is number;
    }

    function canMutatePublicToken() {
      return request.resource.data.publicToken == resource.data.publicToken
        || (isOwner(resource.data.cafeId) && request.resource.data.publicToken != resource.data.publicToken);
    }

    function isValidTableItemCreate() {
      return request.resource.data.cafeId is string
        && request.resource.data.tableId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && isNonNegativeNumber(request.resource.data.unitPrice)
        && isNonNegativeNumber(request.resource.data.totalPrice)
        && request.resource.data.totalPrice == request.resource.data.quantity * request.resource.data.unitPrice
        && request.resource.data.deletedAt == null
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number
        && tableBelongsToCafe(request.resource.data.tableId, request.resource.data.cafeId);
    }

    function isValidTableItemUpdate() {
      return request.resource.data.cafeId == resource.data.cafeId
        && request.resource.data.tableId == resource.data.tableId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && isNonNegativeNumber(request.resource.data.unitPrice)
        && isNonNegativeNumber(request.resource.data.totalPrice)
        && request.resource.data.totalPrice == request.resource.data.quantity * request.resource.data.unitPrice
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is number;
    }

    function isValidLogCreate() {
      return request.resource.data.tableId is string
        && request.resource.data.cafeId is string
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.actionType is string
        && request.resource.data.actorType in ['admin', 'system']
        && request.resource.data.createdAt is number
        && tableBelongsToCafe(request.resource.data.tableId, request.resource.data.cafeId);
    }

    function isValidProjectionWrite() {
      return request.resource.data.cafeId is string
        && request.resource.data.tableId is string
        && request.resource.data.publicToken == publicToken
        && request.resource.data.tableName is string
        && request.resource.data.items is list
        && isNonNegativeNumber(request.resource.data.totalAmount)
        && isNonNegativeNumber(request.resource.data.itemCount)
        && request.resource.data.status in ['empty', 'occupied', 'payment_pending', 'closed']
        && request.resource.data.updatedAt is number
        && tableBelongsToCafe(request.resource.data.tableId, request.resource.data.cafeId)
        // Temporary compatibility allowance for client fallback projection sync.
        // Post-callable deployment: remove these mirror checks from client path and enforce backend-only writes.
        && tableDoc(request.resource.data.tableId).publicToken == request.resource.data.publicToken
        && tableDoc(request.resource.data.tableId).name == request.resource.data.tableName
        && tableDoc(request.resource.data.tableId).status == request.resource.data.status
        && tableDoc(request.resource.data.tableId).itemCount == request.resource.data.itemCount
        && tableDoc(request.resource.data.tableId).totalAmount == request.resource.data.totalAmount;
    }

    match /cafes/{cafeId} {
      allow read: if isOwnerOrManager(cafeId);
      allow create, update, delete: if isOwner(cafeId);
    }

    match /cafeUsers/{userId} {
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /tables/{tableId} {
      allow read: if isOwnerOrManager(resource.data.cafeId);
      allow create: if isOwnerOrManager(request.resource.data.cafeId) && isSafeTableCreate();
      allow update: if isOwnerOrManager(resource.data.cafeId)
        && isSafeTableUpdate()
        && canMutatePublicToken();
      allow delete: if false;
    }

    match /tableItems/{itemId} {
      allow read: if isOwnerOrManager(resource.data.cafeId);
      allow create: if isOwnerOrManager(request.resource.data.cafeId) && isValidTableItemCreate();
      allow update: if isOwnerOrManager(resource.data.cafeId) && isValidTableItemUpdate();
      allow delete: if false;
    }

    match /tableActivityLogs/{logId} {
      allow read: if isOwnerOrManager(resource.data.cafeId);
      // Temporary compatibility allowance: client may append logs.
      // Post-callable deployment: move this to backend-only.
      allow create: if isOwnerOrManager(request.resource.data.cafeId) && isValidLogCreate();
      allow update, delete: if false;
    }

    match /publicTables/{publicToken} {
      allow get, list: if resource.data.deletedAt == null;
      // Public write is denied; only authenticated cafe admins can write a table-mirrored projection.
      allow create, update: if isOwnerOrManager(request.resource.data.cafeId) && isValidProjectionWrite();
      allow delete: if isOwnerOrManager(resource.data.cafeId);
    }

    match /payments/{paymentId} {
      allow read, write: if false;
    }

    match /splitSessions/{splitSessionId} {
      allow read, write: if false;
    }

    match /tableSettlements/{settlementId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
